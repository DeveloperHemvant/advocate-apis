PORT=4000

# Application database only (do not share with admin-panel or AI agent).
# Use a dedicated database name, e.g. advocate_app.
# Example: postgresql://USER:PASSWORD@localhost:5432/advocate_app?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/advocate_app?schema=public

# Change these in production
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Access & refresh TTL (jsonwebtoken format)
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# OTP / SMS (optional)
# Static OTP used when SMS is not configured. Default 123456.
OTP_STATIC_CODE=123456
# When you add an SMS provider, configure its envs here (e.g. SMS_API_KEY, SMS_SENDER, etc.)

# Comma-separated list. Use * for dev if needed.
# Example: http://localhost:19006,http://localhost:5173
CORS_ORIGINS=*

# Used by prisma/seed.ts (optional)
ADMIN_EMAIL=admin@newadv.local
ADMIN_PASSWORD=Admin@12345
