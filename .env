PORT=4000

# App database (inside Docker uses postgres service)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/advocate_app?schema=public

# Change in production
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Access & refresh TTL
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# Allow browser frontends hosted on this server to call the API
# (admin-panel:5173, legal-ai-admin frontend:4300)
CORS_ORIGINS=http://43.205.165.14:5173,http://43.205.165.14:4300

# Used by prisma/seed.ts (optional)
ADMIN_EMAIL=admin@newadv.local
ADMIN_PASSWORD=Admin@12345