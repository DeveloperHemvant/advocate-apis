PORT=4000

# Example: postgresql://USER:PASSWORD@localhost:5432/newadv?schema=public
DATABASE_URL=postgresql://postgres:Developer@014789@localhost:5432/Advocatefinal?schema=public
# Change these in production
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Access & refresh TTL (jsonwebtoken format)
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d

# Comma-separated list. Use * for dev if needed.
# Example: http://localhost:19006,http://localhost:5173
CORS_ORIGINS=*

# Used by prisma/seed.ts (optional)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345678
