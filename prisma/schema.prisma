generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADVOCATE
  ADMIN
}

enum ProfileStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  phone         String?
  passwordHash  String
  fullName      String
  role          Role           @default(ADVOCATE)
  isActive      Boolean        @default(true)

  // Advocate onboarding/profile fields
  barId          String?
  experienceYears Int?
  practiceAreas  String[]
  city           String?
  state          String?
  profileStatus  ProfileStatus @default(PENDING)

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("ActorAuditLogs")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([role])
  @@index([profileStatus])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  meta        Json?
  createdAt   DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
}

model TrainingDraft {
  id           String   @id @default(cuid())
  userId       String?
  documentType String   @map("document_type")
  title        String?  @db.Text
  facts        String?  @db.Text
  draftText    String   @map("draft_text") @db.Text
  courtType    String?  @map("court_type")
  state        String?
  approvedAt   DateTime @default(now()) @map("approved_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([documentType])
}

